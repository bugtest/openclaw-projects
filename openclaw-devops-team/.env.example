# OpenClaw DevOps 环境变量示例
# 复制此文件为 .env 并填入实际值

# =====================
# 飞书配置 (DevBot)
# =====================
FEISHU_DEVBOT_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_DEVBOT_APP_SECRET=your-app-secret-here
FEISHU_DEVBOT_TOKEN=your-verification-token-here
FEISHU_DEVBOT_CHANNEL=oc_xxxxxxxxxxxxxxxx

# =====================
# 飞书配置 (CIBot)
# =====================
FEISHU_CIBOT_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_CIBOT_APP_SECRET=your-app-secret-here
FEISHU_CIBOT_TOKEN=your-verification-token-here
FEISHU_CIBOT_CHANNEL=oc_xxxxxxxxxxxxxxxx

# =====================
# 飞书配置 (CDBot)
# =====================
FEISHU_CDBOT_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_CDBOT_APP_SECRET=your-app-secret-here
FEISHU_CDBOT_TOKEN=your-verification-token-here
FEISHU_CDBOT_CHANNEL=oc_xxxxxxxxxxxxxxxx

# =====================
# GitHub 配置
# =====================
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=bugtest
GITHUB_REPO=openclaw-projects
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# =====================
# OpenClaw 配置
# =====================
OPENCLAW_GATEWAY_URL=http://localhost:8080
OPENCLAW_MODEL=bailian/qwen3.5-plus

# =====================
# 部署配置
# =====================
DEPLOY_STAGING_URL=https://staging.example.com
DEPLOY_PROD_URL=https://www.example.com
DEPLOY_STRATEGY=bluegreen
